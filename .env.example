# ============================================================
# 组合动力智能评估平台 —— 环境变量示例（复制为 .env）
# ============================================================

# ---- 大模型配置（对齐 DataAgent：.env 默认 + 前端 BYOK 覆盖）----
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ---- 数据库（评估元数据）----
# 默认项目根下 sqlite；可换 Postgres：postgresql+psycopg://user:pwd@host/db
EVAL_DB_URL=sqlite:///./eval_platform.db

# ---- 自有资产路径（解析 / 判据 / 切片渲染）----
SIMPARSE_PKG=D:/Git/GitBubProj/simcli/sim-parse/src
SIM_KNOWLEDGE=D:/Git/GitBubProj/simcli/sim-knowledge
SIMGRAPH2_ROOT=D:/Git/SimGraph2
# 带 VTK+Romtek 的渲染环境（四切片子进程调用）
POSTPROCESS_PYTHON=D:/TOOL/Conda/conda/envs/PostProcessTool/python.exe

# ---- GPU（本项目固定 cuda:6,7）----
EVAL_CUDA=6,7
